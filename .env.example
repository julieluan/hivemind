# Copy to .env.local and fill in your keys.
# .env.local is gitignored — never commit your real key.

# ── LLM provider (required when going live) ───────────────────────────────────
# Get your key from the LLM provider that issued it.
# Common base URLs:
#   MiniMax international:  https://api.minimax.io/v1
#   MiniMax China:          https://api.minimaxi.chat/v1
#   OpenAI:                 https://api.openai.com/v1
#   Anthropic:              https://api.anthropic.com/v1   (uses x-api-key header)
#   Internal proxy:         https://your-gateway/v1
LLM_PROVIDER=minimax
LLM_API_KEY=
LLM_BASE_URL=https://api.minimax.io/v1
LLM_MODEL=MiniMax-M2

# ── Optional: market data ─────────────────────────────────────────────────────
# Without this, /api/market/price falls back to bundled sample data in public/data/.
ALPHA_VANTAGE_KEY=

# ── Optional: server-side caching (Vercel KV) ─────────────────────────────────
# If set, agent decisions get cached so repeat-day = free.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Misc ──────────────────────────────────────────────────────────────────────
# Set to "mock" during frontend development to avoid burning LLM credits.
NEXT_PUBLIC_USE_MOCK_AGENTS=false
